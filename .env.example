# --- GrowVera environment ---

# Site
NEXT_PUBLIC_SITE_URL=https://growvera.com.au

# Existing: Zoho SMTP for the /audit lead form
ZOHO_SMTP_PASS=

# --- Stripe subscriptions (MRR) ---
# Server-side secret key (sk_live_... / sk_test_...)
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_...) for /api/stripe-webhook
STRIPE_WEBHOOK_SECRET=

# Phase 2 — recurring Price IDs (price_...) for Checkout Sessions
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_AGENCY=

# Phase 1 — hosted Stripe Payment Links (subscription mode). If set, the
# Subscribe button links straight to these and skips /api/checkout.
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_STARTER=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_PRO=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_AGENCY=

# --- Supabase (entitlement persistence; optional in dev) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Pipeline (Workstream B) — cheapest-first model routing ---
#
# Default (recommended): one OpenRouter key reaches every open model and keeps
# the pipeline OFF the metered Claude pool — ~35x cheaper. Set a hard spend cap
# on the key. If OPENROUTER_API_KEY is set, it is used for all programmatic work.
OPENROUTER_API_KEY=
# Optional model overrides (point at the current best/cheapest without code edits)
OPENROUTER_MODEL_BUILD=z-ai/glm-4.6
OPENROUTER_MODEL_CHEAP=deepseek/deepseek-chat
OPENROUTER_MODEL_REVIEW=qwen/qwen2.5-vl-72b-instruct

# Frontier (Anthropic) — opt-in only. Used when OPENROUTER_API_KEY is absent,
# or force it for a high-stakes run with USE_FRONTIER=1.
ANTHROPIC_API_KEY=
# USE_FRONTIER=1

# Live prospecting (real businesses with no website). Without it, sample data.
GOOGLE_PLACES_API_KEY=
