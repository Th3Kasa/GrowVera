# --- GrowVera environment ---

# Site
NEXT_PUBLIC_SITE_URL=https://growvera.com.au

# Existing: Zoho SMTP for the /audit lead form
ZOHO_SMTP_PASS=

# --- Stripe subscriptions (MRR) ---
# Server-side secret key (sk_live_... / sk_test_...)
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_...) for /api/stripe-webhook
STRIPE_WEBHOOK_SECRET=

# Phase 2 — recurring Price IDs (price_...) for Checkout Sessions
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_AGENCY=

# Phase 1 — hosted Stripe Payment Links (subscription mode). If set, the
# Subscribe button links straight to these and skips /api/checkout.
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_STARTER=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_PRO=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_AGENCY=

# --- Supabase (entitlement persistence; optional in dev) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Pipeline (Workstream B) ---
ANTHROPIC_API_KEY=
GOOGLE_PLACES_API_KEY=
